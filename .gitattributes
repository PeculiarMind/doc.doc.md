# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly declare files that should always use LF
*.sh text eol=lf
*.bash text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf

# Denote binary files that should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
